{
	"name": "petedio-resume-builder",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"bun": ">=1.3.14"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "bun test",
		"seed": "bun run scripts/seed-profile.ts",
		"seed:workspace": "bun run scripts/seed-workspace.ts"
	},
	"dependencies": {
		"jose": "6.2.3",
		"mongodb": "7.5.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "5.5.7",
		"@sveltejs/kit": "2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.1.1",
		"svelte": "5.56.7",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "8.1.5"
	}
}
