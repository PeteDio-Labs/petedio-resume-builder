# Copy to .env for local dev. Never commit real values — this repo is public.

# --- Cloudflare Access (auth) ---
# Team domain for JWKS verification, no protocol, e.g. "your-team.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
# The Access application's Audience (AUD) tag
CF_ACCESS_AUD=changeme-aud-tag

# Comma-separated allow-list of verified emails permitted to use the app.
# Deny-by-default: any verified identity NOT in this list gets a 403.
ALLOWED_USERS=user@example.com

# Dev-only: local dev has no Cloudflare edge in front of it, so the
# Cf-Access-Jwt-Assertion header never arrives. Set this to an email (that's
# also in ALLOWED_USERS) to fake a signed-in identity when running
# `bun run dev`. Has no effect in a production build — see
# src/lib/server/auth.ts for the guard. Leave unset to exercise the
# "not signed in" / fail-closed path.
DEV_FAKE_IDENTITY=

# --- Demo mode ---
# A single switch that fakes the app's external dependencies (MongoDB now,
# Ollama/AI later) with in-memory stand-ins, so the whole app runs standalone
# for showing it off — the same idea as the palworld panel's PANEL_APPLIER=demo.
# Off by default. When "true":
#   * the data layer uses an in-memory store seeded with a synthetic sample
#     profile (no MongoDB needed) — data resets when the server restarts;
#   * in local dev only, you're auto-signed-in as the demo user, so a standalone
#     demo needs just this one line. In a production build it still requires a
#     real Cloudflare Access login (demo mode only fakes data there, never auth).
DEMO_MODE=false
# Which identity demo data is seeded for / viewed as. Defaults to the first
# ALLOWED_USERS entry, else demo@resume.local. Usually leave unset.
DEMO_USER=

# --- MongoDB ---
# Not provisioned yet (P1 scope) — placeholder only. Ignored in demo mode.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=resume_builder
